{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Launch Emulator",
      "type": "shell",
      "command": "flutter",
      "args": [
        "emulators",
        "--launch",
        "Pixel_10"
      ],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*$",
          "endsPattern": "^.*$"
        }
      }
    }
  ]
}
